{
  "name": "textrova",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "install": "npm --prefix backend install && npm --prefix frontend install",
    "start": "concurrently \"npm --prefix backend run start\" \"npm --prefix frontend run dev\"",
    "start:backend": "npm --prefix backend run start",
    "start:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "formidable": "^3.5.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
